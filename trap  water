import  java.util.*;
public class main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        
        int n=sc.nextInt();
        int[] arr=new  int[n];
        
        for(int i=0;i<n;i++){
            arr[i]=sc.nextInt();
        }
        
        int currsum=arr[0];
        int max=arr[0];
        
        for(int i=1;i<n;i++){
            if(currsum+arr[i]>arr[i]){
                currsum+=arr[i];
            }
            else{
                currsum=arr[i];
            }
            if(currsum>max){
                max=currsum;
            }
        }
        System.out.println(max);
        sc.close();
    }
}
