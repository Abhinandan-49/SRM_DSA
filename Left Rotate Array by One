class Solution {
    public int removeDuplicates(int[] nums) {
        int i = 0; // points to last unique element

        for (int j = 1; j < nums.length; j++) {
            if (nums[j] != nums[i]) { // new unique element found
                i++;
                nums[i] = nums[j];
            }
        }

        return i + 1; // number of unique elements
    }
}
